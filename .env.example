# Environment Variables Reference
# Copy to `.env.local` for local development and fill in your values

## ============================================
## REQUIRED - Cloudflare Configuration
## ============================================

# Get from https://dash.cloudflare.com/account/api-tokens
# Create a token with: Workers Scripts (Edit), D1 (Edit), R2 (Edit), Pages (Edit)
CLOUDFLARE_API_TOKEN=-gjyxa7C3tSZsqWgs60lbuHE1XTs-ZofkaFIOLf6

# Get from https://dash.cloudflare.com (check right sidebar on any page)
CLOUDFLARE_ACCOUNT_ID=0e528c886015cce349076fb7db222a88

## ============================================
## Database Configuration
## ============================================

# Get after running: npm run db:init
# Looks like: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
D1_DATABASE_ID=your_database_id_here

# Name of your D1 database
D1_DATABASE_NAME=smb-crm-db

## ============================================
## Authentication & Security (IMPORTANT!)
## ============================================

# Generate with: openssl rand -hex 32
# Change this value for production - DO NOT use default
JWT_SECRET=rspQOj2pF0oJcXE9aNhzlr9AHMBfYcos

# JWT token expiry in seconds
# Default: 86400 (24 hours)
JWT_EXPIRY=86400

# Refresh token expiry in seconds
# Default: 604800 (7 days)
JWT_REFRESH_EXPIRY=604800

## ============================================
## R2 Storage Configuration
## ============================================

# R2 bucket name for file uploads
R2_BUCKET_NAME=smb-crm-storage

# R2 bucket region (default: auto)
R2_BUCKET_REGION=auto

## ============================================
## Environment Settings
## ============================================

# Runtime environment (development, staging, production)
ENVIRONMENT=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# API CORS origin - change for production
API_CORS_ORIGIN=http://localhost:5173

# API port for local development
API_PORT=8787

## ============================================
## Frontend Configuration
## ============================================

# API URL for frontend (used during build)
# Local: http://localhost:8787
# Production: https://api.yourdomain.com or https://smb-crm-api.workers.dev
VITE_API_URL=http://localhost:8787

# App name shown in UI
VITE_APP_NAME=SMB CRM

# Frontend URL
VITE_APP_URL=http://localhost:5173

# Enable debug mode in frontend
VITE_DEBUG=false

## ============================================
## Email Configuration (Future Use)
## ============================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

## ============================================
## Feature Flags
## ============================================

# Enable registration (disable for invite-only)
FEATURE_REGISTRATION_ENABLED=true

# Enable file uploads
FEATURE_FILE_UPLOADS=true

# Enable analytics
FEATURE_ANALYTICS=false

## ============================================
## How to Generate JWT_SECRET
## ============================================

# Mac/Linux:
# openssl rand -hex 32

# Windows (PowerShell):
# [System.Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))

# Or use an online tool: https://randomkeygen.com/
